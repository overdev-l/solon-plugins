{
  "$schema": "../../schemas/manifest.schema.json",
  "schema_version": 1,
  "id": "lark-cli",
  "type": "cli",
  "name": "飞书 CLI (lark-cli)",
  "description": "飞书官方 CLI，200+ 命令覆盖消息、文档、表格、日历、邮件、任务、会议等业务域，面向人类与 AI Agent。",
  "version": "1.0.12",
  "author": "Lark Suite",
  "license": "MIT",
  "homepage": "https://github.com/larksuite/cli",
  "permissions": [
    "exec",
    "keychain",
    {
      "network": [
        "open.larksuite.com",
        "open.feishu.cn",
        "www.larksuite.com",
        "www.feishu.cn"
      ]
    }
  ],
  "assets": {
    "darwin-arm64": {
      "url": "https://github.com/larksuite/cli/releases/download/v1.0.12/lark-cli-1.0.12-darwin-arm64.tar.gz",
      "sha256": "c84bd10c294210c094155d1e08e6d665a4b76f62fd01c9cb5c457691c01ae78c",
      "size": 5906607,
      "archive": "tar.gz",
      "entry": "lark-cli"
    },
    "darwin-x64": {
      "url": "https://github.com/larksuite/cli/releases/download/v1.0.12/lark-cli-1.0.12-darwin-amd64.tar.gz",
      "sha256": "7f947ade30809613db4cb7d953c01996b0654ee174f2608c5883716a309f4f4d",
      "size": 6231793,
      "archive": "tar.gz",
      "entry": "lark-cli"
    }
  },
  "spec": {
    "command": "lark-cli",
    "bash_rewrite": false
  },
  "post_install": {
    "message_zh": "首次使用需要创建飞书应用并完成授权。",
    "message_en": "First-time setup: create a Lark app and complete authorization.",
    "setup_steps": [
      { "command": "lark-cli config init --new", "label_zh": "创建飞书应用", "label_en": "Create Lark App" },
      { "command": "lark-cli auth login", "label_zh": "授权登录", "label_en": "Authorize" }
    ]
  }
}
