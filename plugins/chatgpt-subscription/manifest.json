{
  "$schema": "../../schemas/manifest.schema.json",
  "schema_version": 1,
  "id": "chatgpt-subscription",
  "type": "provider",
  "name": "ChatGPT 订阅",
  "description": "使用 ChatGPT Plus / Pro / Team 订阅作为模型后端，通过 OAuth 登录，无需 API Key。",
  "version": "0.4.0",
  "author": "overdev-l",
  "license": "MIT",
  "homepage": "https://github.com/overdev-l/solon-plugins",
  "permissions": [
    "keychain",
    { "network": ["auth.openai.com", "chatgpt.com"] }
  ],
  "spec": {
    "sdk": "openai",
    "base_url": "https://chatgpt.com/backend-api/codex",
    "api_format": "openai-responses",
    "auth": {
      "type": "oauth_pkce",
      "authorize_url": "https://auth.openai.com/oauth/authorize",
      "token_url": "https://auth.openai.com/oauth/token",
      "client_id": "app_EMoamEEZ73f0CkXaXp7hrann",
      "scopes": ["openid", "profile", "email", "offline_access", "api.connectors.read", "api.connectors.invoke"],
      "redirect_port": 1455,
      "redirect_path": "/auth/callback",
      "extra_authorize_params": {
        "id_token_add_organizations": "true",
        "codex_cli_simplified_flow": "true",
        "originator": "codex_cli_rs"
      },
      "account_id_claim": "https://api.openai.com/auth/chatgpt_account_id"
    },
    "request_headers": {
      "Chatgpt-Account-Id": "$ACCOUNT_ID",
      "Originator": "codex_cli_rs",
      "User-Agent": "codex_cli_rs/0.0.0 (Mac OS 14.5; arm64) Terminal.app/1.0 (codex_cli_rs; 0.0.0)",
      "Session_id": "$SESSION_ID"
    },
    "models": [
      { "id": "gpt-5", "name": "GPT-5" },
      { "id": "gpt-5-mini", "name": "GPT-5 mini" },
      { "id": "gpt-4.1", "name": "GPT-4.1" },
      { "id": "o3", "name": "o3" },
      { "id": "o4-mini", "name": "o4-mini" }
    ],
    "runtime_hooks": {
      "on_response": {
        "extract": [
          {
            "id": "rate_limit_5h",
            "from": "response_headers",
            "fields": {
              "used_percent": "x-codex-primary-used-percent",
              "window_minutes": "x-codex-primary-window-minutes",
              "resets_at": "x-codex-primary-reset-at"
            }
          },
          {
            "id": "rate_limit_week",
            "from": "response_headers",
            "fields": {
              "used_percent": "x-codex-secondary-used-percent",
              "window_minutes": "x-codex-secondary-window-minutes",
              "resets_at": "x-codex-secondary-reset-at"
            }
          }
        ]
      }
    },
    "status_panels": [
      {
        "type": "progress_bar_list",
        "title": { "zh": "订阅额度", "en": "Subscription usage" },
        "bars": [
          {
            "source": "rate_limit_5h",
            "label": { "zh": "5 小时窗口", "en": "5-hour window" },
            "percent_field": "used_percent",
            "subtitle_field": "window_minutes",
            "subtitle_format": "duration_minutes",
            "footer_field": "resets_at",
            "footer_format": "relative_time"
          },
          {
            "source": "rate_limit_week",
            "label": { "zh": "每周窗口", "en": "Weekly window" },
            "percent_field": "used_percent",
            "subtitle_field": "window_minutes",
            "subtitle_format": "duration_minutes",
            "footer_field": "resets_at",
            "footer_format": "relative_time"
          }
        ]
      }
    ]
  },
  "post_install": {
    "message_zh": "打开设置 → AI Provider → 插件接入 → ChatGPT 订阅，点击「打开浏览器登录」完成授权即可使用。",
    "message_en": "Open Settings → AI Provider → Plugins → ChatGPT Subscription and click \"Sign in in browser\" to authorize."
  }
}
