{
  "$schema": "../../schemas/manifest.schema.json",
  "schema_version": 1,
  "id": "rtk",
  "type": "cli",
  "name": "RTK - Rust Token Killer",
  "description": "CLI 代理，拦截 git/docker/cargo/npm 等命令的输出并压缩，Solon AI Agent 会话可节省 60-90% token。",
  "version": "0.34.0",
  "author": "rtk-ai",
  "license": "MIT",
  "homepage": "https://github.com/rtk-ai/rtk",
  "permissions": ["exec"],
  "assets": {
    "darwin-arm64": {
      "url": "https://github.com/rtk-ai/rtk/releases/download/v0.34.0/rtk-aarch64-apple-darwin.tar.gz",
      "sha256": "9559c96032bd99155bfd480afb4aedc170744ba87d959dda40b8981dc542877b",
      "size": 3512152,
      "archive": "tar.gz",
      "entry": "rtk"
    },
    "darwin-x64": {
      "url": "https://github.com/rtk-ai/rtk/releases/download/v0.34.0/rtk-x86_64-apple-darwin.tar.gz",
      "sha256": "626c7f139542cafddd2fd5b630b0b1d580db1ff98a93d0c499fa6712969fdc68",
      "size": 3872849,
      "archive": "tar.gz",
      "entry": "rtk"
    }
  },
  "spec": {
    "command": "rtk",
    "bash_rewrite": true,
    "rewrite_targets": [
      "git",
      "docker",
      "kubectl",
      "cargo",
      "npm",
      "pnpm",
      "yarn",
      "pytest",
      "go",
